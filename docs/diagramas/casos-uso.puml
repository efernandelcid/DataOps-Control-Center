@startuml
title Diagrama de Casos de Uso General - DataOps Control Center

left to right direction

actor "Administrador" as Admin
actor "Sistema Cron" as Cron
actor "Base de Datos Monitoreada" as DB
actor "pgAdmin" as PgAdmin

rectangle "DataOps Control Center" {

  usecase "Visualizar dashboard" as UC1
  usecase "Consultar conexiones" as UC2
  usecase "Filtrar conexiones" as UC3
  usecase "Ejecutar check manual" as UC4
  usecase "Ver alertas críticas" as UC5
  usecase "Ver métricas avanzadas" as UC6
  usecase "Ver historial de monitoreo" as UC7
  usecase "Exportar reporte CSV" as UC8
  usecase "Consultar estado general del sistema" as UC9

  usecase "Ejecutar monitoreo automático" as UC10
  usecase "Registrar logs de salud" as UC11
  usecase "Registrar métricas avanzadas" as UC12
  usecase "Actualizar estado de conexión" as UC13
  usecase "Limpiar logs antiguos" as UC14

  usecase "Administrar base de datos central" as UC15
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9

Cron --> UC10
Cron --> UC14

UC10 --> UC11 : <<include>>
UC10 --> UC12 : <<include>>
UC10 --> UC13 : <<include>>

DB --> UC10

PgAdmin --> UC15

@enduml